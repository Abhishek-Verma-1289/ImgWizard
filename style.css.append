/* Crop overlay transition effects */
@keyframes cropOverlayFadeIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes cropOverlayFadeOut {
  from {
    opacity: 1;
    transform: scale(1);
  }
  to {
    opacity: 0;
    transform: scale(0.95);
  }
}

#cropOverlay {
  animation: cropOverlayFadeIn 0.2s ease-out;
}
